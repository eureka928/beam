# Beam node environment (orchestrator, worker, validator)
# Copy to `.env` and adjust. Never commit `.env`.
#
# Public Beam endpoints:
# CORE_SERVER_URL      -> Beam control plane
# ORCH_GATEWAY_URL     -> orchestrator WebSocket gateway
# WORKER_GATEWAY_URL   -> public worker WebSocket gateway

# =============================================================================
# MAINNET
# =============================================================================
CORE_SERVER_URL=https://beamcore.b1m.ai
ORCH_GATEWAY_URL=https://orch-gateway.b1m.ai
WORKER_GATEWAY_URL=https://public-worker-gateway.b1m.ai

SUBTENSOR_NETWORK=finney
NETUID=105

# =============================================================================
# ORCHESTRATOR
# =============================================================================
WALLET_NAME=orchestrator
WALLET_HOTKEY=default
# WALLET_PATH=~/.bittensor/wallets
# READY=true

# LOG_LEVEL=INFO

# =============================================================================
# VALIDATOR
# =============================================================================
BEAM_VALIDATOR_WALLET_NAME=validator
BEAM_VALIDATOR_WALLET_HOTKEY=default
# BEAM_VALIDATOR_WALLET_PATH=~/.bittensor/wallets

BEAM_VALIDATOR_CORE_SERVER_URL=https://beamcore.b1m.ai

# BEAM_VALIDATOR_LOG_LEVEL=INFO
